# PostgreSQL
POSTGRES_USER=invoice_user
POSTGRES_PASSWORD=invoice_pass
POSTGRES_DB=invoice_manager
DATABASE_URL=postgresql://invoice_user:invoice_pass@postgres:5432/invoice_manager

# OIDC Authentication (required for production)
# Provide OIDC_DISCOVERY_URL (preferred) or OIDC_ISSUER_URL
# Authentik example: https://auth.example.com/application/o/invoice-manager/.well-known/openid-configuration
OIDC_DISCOVERY_URL=
# OIDC_ISSUER_URL=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
# OIDC_REDIRECT_URI=             # optional: auto-detected from request; set only behind reverse proxies
# OIDC_POST_LOGOUT_REDIRECT_URI=  # defaults to origin of OIDC_REDIRECT_URI (or request origin)
# OIDC_SCOPES=openid email profile
# OIDC_NAME=SSO
# OIDC_AUTO_CREATE_USER=true

# Session
# SESSION_MAX_AGE=1800

# Development — skip OIDC, auto-login as admin
# BYPASS_LOGIN=true
