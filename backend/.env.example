DATABASE_URL=postgresql://invoice_user:invoice_pass@localhost:5432/invoice_manager
PORT=3000

# OIDC Authentication
# Provide OIDC_DISCOVERY_URL (preferred) or OIDC_ISSUER_URL
# Authentik example: https://auth.example.com/application/o/invoice-manager/.well-known/openid-configuration
OIDC_DISCOVERY_URL=
# OIDC_ISSUER_URL=              # alternative: library appends /.well-known/openid-configuration
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URI=http://localhost:5173/api/auth/callback
# OIDC_POST_LOGOUT_REDIRECT_URI=  # defaults to origin of OIDC_REDIRECT_URI
# OIDC_SCOPES=openid email profile
# OIDC_NAME=SSO
# OIDC_AUTO_CREATE_USER=true    # set to false to reject unknown users

# Session
# SESSION_MAX_AGE=1800          # 30 minutes in seconds

# Development
# BYPASS_LOGIN=true             # skip OIDC, auto-login as __admin__
